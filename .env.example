# Firebase config (Vite expects VITE_ prefix)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Notes:
# 1) In the Firebase Console, add a Web app and copy the config values above.
# 2) To enable GitHub sign-in: Authentication -> Sign-in method -> GitHub -> Enable.
#    You must register an OAuth App on GitHub and provide Client ID and Client Secret
#    to Firebase. Set the Authorization callback URL in GitHub to:
#    https://your-project-id.firebaseapp.com/__/auth/handler
# 3) Restart the Vite dev server after adding .env file so import.meta.env updates.
# 4) Never commit your real .env to source control; keep secrets private.
